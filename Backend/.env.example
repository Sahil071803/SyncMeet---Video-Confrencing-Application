API_PORT=5002

MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/videoconferencing

JWT_SECRET=yourSuperSecretKey

# ── Email Provider ──────────────────────────────────
# Option A: SendGrid (recommended for Render/cloud)
#   Create free account at https://sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Option B: Gmail App Password (works locally, may fail on cloud)
#   Enable 2FA on Google Account → Security → App Passwords
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_16_char_app_password

# Frontend URL for invitation links
FRONTEND_URL=http://localhost:5173
